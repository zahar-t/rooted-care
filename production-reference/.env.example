# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Required inside Docker (no `claude` CLI fallback in the container).
# Live LLM calls happen only via scripts/smoke_live.sh and POST /v1/eval.
ANTHROPIC_API_KEY=

# Shared header secret for every /v1/* endpoint. Generate with:
#   openssl rand -hex 24
ROOTED_API_KEY=

# Model the frozen brain calls. Left at its default on purpose — the
# "why Opus at £15/mo" cost-tier question is a deliberately-open trade-off.
AUTOPILOT_MODEL=claude-opus-4-8

# Keep the fixture clock (2026-07-01) so replacement-window maths matches the
# committed fixtures. Production would set 1 to use the real system date.
LIVE_CLOCK=0

# Telegram chat ids for the n8n workflows. Captured once by messaging /start to
# your bot (see docs/n8n-setup.md). SOFIA_CHAT_ID gets approvals + digests;
# OPERATOR_CHAT_ID gets route-failure and eval-crash alerts (can be the same id).
SOFIA_CHAT_ID=
OPERATOR_CHAT_ID=
