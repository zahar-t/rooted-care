{
  "name": "01 Inbound DM",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "rooted-dm",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        300
      ],
      "webhookId": "rooted-dm"
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { \"ok\": true } }}",
        "options": {}
      },
      "id": "respond-to-webhook",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        220,
        140
      ]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Normalise an inbound DM to the /v1/route contract. Content is NOT inspected —\n// this only shapes fields and derives a stable message_id for idempotency.\nconst crypto = require('crypto');\nconst src = $input.first().json;\nconst body = src.body || src;                    // webhook payload lives under .body\nconst handle = String(body.handle || '').replace(/^@/, '');\nconst text = String(body.text || '');\nlet messageId = String(body.message_id || '');\nif (!messageId) {\n  messageId = crypto.createHash('sha256').update(handle + text).digest('hex').slice(0, 16);\n}\nreturn [{ json: { message_id: messageId, handle, text, channel: 'instagram' } }];"
      },
      "id": "normalize",
      "name": "Normalize",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        420
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://rooted-api:8000/v1/route",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {
          "timeout": 180000
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"message_id\": $json.message_id, \"handle\": $json.handle, \"text\": $json.text, \"channel\": $json.channel } }}"
      },
      "id": "route",
      "name": "Route",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        440,
        420
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_WITH_CREDENTIAL_ID",
          "name": "Rooted API Key"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000,
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $env.OPERATOR_CHAT_ID }}",
        "text": "=⚠️ route failed — raw DM attached, nothing was sent.\\n{{ JSON.stringify($('Normalize').item.json) }}",
        "additionalFields": {}
      },
      "id": "route-failed-alert",
      "name": "Route Failed Alert",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        660,
        620
      ],
      "credentials": {
        "telegramApi": {
          "id": "REPLACE_WITH_CREDENTIAL_ID",
          "name": "Rooted Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "mode": "rules",
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "typeValidation": "loose"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.action }}",
                    "rightValue": "auto_send",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "auto_send"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "typeValidation": "loose"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.action }}",
                    "rightValue": "ack_and_queue",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "ack_and_queue"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "typeValidation": "loose"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.action }}",
                    "rightValue": "queue",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "queue"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "typeValidation": "loose"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.action }}",
                    "rightValue": "duplicate",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "duplicate"
            }
          ]
        },
        "options": {}
      },
      "id": "switch",
      "name": "Switch",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        660,
        400
      ]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// PLACEHOLDER for the real Instagram \"send DM\" node. Swap this out for the\n// channel node later — README marks this seam. For now it just logs.\nconst d = $input.first().json;\nconsole.log('PLACEHOLDER SEND (instagram):', JSON.stringify({\n  handle: d.handle, reply_to_send: d.reply_to_send, reply_kind: d.reply_kind,\n}));\nreturn [{ json: d }];"
      },
      "id": "send-care",
      "name": "Send Care",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        120
      ]
    },
