    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $env.SOFIA_CHAT_ID }}",
        "text": "={{ ($('Route').item.json.queued.urgency === 'high' ? '‼️ URGENT\\n' : '') + '🪴 ' + $('Route').item.json.queued.type + ' — @' + $('Route').item.json.handle + '\\n' + $('Route').item.json.queued.summary + '\\n\\nNotes: ' + $('Route').item.json.queued.notes + ($('Route').item.json.queued.draft_reply ? '\\n\\nDraft:\\n' + $('Route').item.json.queued.draft_reply.slice(0,300) : '') }}",
        "additionalFields": {},
