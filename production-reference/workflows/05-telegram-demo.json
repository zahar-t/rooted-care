{
  "name": "05 Telegram Demo",
  "nodes": [
    {
      "parameters": {
        "updates": [
          "message"
        ],
        "additionalFields": {}
      },
      "id": "telegram-trigger-demo",
      "name": "Telegram Trigger (Demo)",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        300
      ],
      "credentials": {
        "telegramApi": {
          "id": "REPLACE_WITH_CREDENTIAL_ID",
          "name": "Rooted Telegram Bot"
        }
      },
      "webhookId": "rooted-demo"
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Shape an inbound Telegram DM into the /v1/route contract. Content is NOT\n// inspected — this only maps Telegram fields and derives a stable message_id.\n// The frozen brain makes every judgement; this workflow just relays its\n// customer-facing reply back to the same chat.\nconst u = $input.first().json;\nconst msg = u.message || {};\nconst from = msg.from || {};\nconst chat = msg.chat || {};\nconst text = typeof msg.text === 'string' ? msg.text.trim() : '';\n\n// handle: the Telegram username if it fits the API's handle rule, else tg<id>.\nlet handle = String(from.username || '').replace(/^@/, '');\nif (!/^[A-Za-z0-9._]{1,64}$/.test(handle)) handle = 'tg' + (from.id || 'anon');\n\n// message_id: unique per Telegram message, sanitised to the API's id rule.\nconst messageId = ('tg-' + (chat.id ?? 'x') + '-' + (msg.message_id ?? 'x'))\n  .replace(/[^A-Za-z0-9._-]/g, '').slice(0, 64);\n\nreturn [{ json: {\n  message_id: messageId, handle, text, channel: 'telegram',\n  chat_id: chat.id, has_text: text.length > 0,\n} }];"
      },
      "id": "shape-dm",
      "name": "Shape DM",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "leftValue": "={{ $json.has_text }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "has-text",
      "name": "Has Text?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        440,
        300
      ]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $('Shape DM').item.json.chat_id }}",
        "text": "👋 Send me a text message — a customer DM to Rooted — and I'll show you how the autopilot handles it.",
        "additionalFields": {}
      },
      "id": "ask-for-text",
      "name": "Ask For Text",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        660,
        480
      ],
      "credentials": {
        "telegramApi": {
          "id": "REPLACE_WITH_CREDENTIAL_ID",
          "name": "Rooted Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://rooted-api:8000/v1/route",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {
          "timeout": 180000
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"message_id\": $json.message_id, \"handle\": $json.handle, \"text\": $json.text, \"channel\": $json.channel } }}"
      },
      "id": "route-demo",
      "name": "Route (Demo)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        660,
        200
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_WITH_CREDENTIAL_ID",
          "name": "Rooted API Key"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000,
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $('Shape DM').item.json.chat_id }}",
        "text": "⚠️ Couldn't route that one — is ANTHROPIC_API_KEY set and the API healthy?",
        "additionalFields": {}
      },
      "id": "route-failed-demo",
      "name": "Route Failed (Demo)",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        880,
